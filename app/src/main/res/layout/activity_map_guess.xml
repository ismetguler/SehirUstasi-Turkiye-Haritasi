<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".MapGuessActivity">

    <LinearLayout
        android:id="@+id/scoreAndLivesLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textViewScoreMap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/score_and_question_text"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="start"
            tools:text="Puan: 0 | Soru: 0/81"
            android:layout_weight="1"
            android:paddingStart="8dp" />

        <ImageView
            android:id="@+id/imageViewHeart1Map"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/heart_icon_description"
            android:src="@drawable/ic_heart_full"
            app:tint="@color/red_heart" />

        <ImageView
            android:id="@+id/imageViewHeart2Map"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/heart_icon_description"
            android:src="@drawable/ic_heart_full"
            app:tint="@color/red_heart" />

        <ImageView
            android:id="@+id/imageViewHeart3Map"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/heart_icon_description"
            android:src="@drawable/ic_heart_full"
            app:tint="@color/red_heart" />

        <ImageView
            android:id="@+id/imageViewHeart4Map"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/heart_icon_description"
            android:src="@drawable/ic_heart_full"
            app:tint="@color/red_heart" />

        <ImageView
            android:id="@+id/imageViewHeart5Map"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/heart_icon_description"
            android:src="@drawable/ic_heart_full"
            app:tint="@color/red_heart" />
    </LinearLayout>

    <TextView
        android:id="@+id/textViewCityNameQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/rounded_background"
        android:padding="12dp"
        android:text="@string/city_guess_prompt"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scoreAndLivesLayout"
        tools:text="Şehri Bul: Ankara" />

    <TextView
        android:id="@+id/textViewMapInstruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:text="Haritayı yakınlaştırıp kaydırarak şehri bulabilir ve işaretleyebilirsiniz."
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewCityNameQuestion" />

    <com.ismetguler.sehirtahmin.MapView
        android:id="@+id/mapViewGame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@color/map_background_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewMapInstruction" />

    <LinearLayout
        android:id="@+id/layoutGameOverMap"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#E5000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textViewMapGameOver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oyun Bitti!"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/textViewMapResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bu turda bildiğin şehir: 0"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textViewMapRecord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rekorun: 0"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/buttonWatchAdMap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reklam İzle, 3 Can Kazan"
            android:backgroundTint="@color/my_primary_color"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:textSize="20sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/buttonPlayAgainMap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yeniden Oyna"
            android:backgroundTint="@color/teal_200"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:textSize="20sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/buttonExitToMenuMap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menüye Dön"
            android:backgroundTint="@color/my_error_color"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:textSize="20sp"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>